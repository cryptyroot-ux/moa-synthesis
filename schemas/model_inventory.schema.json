{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MoA Synthesis Model Inventory",
  "type": "object",
  "required": [
    "generated_at",
    "models"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "hermes_home": {
      "type": "string"
    },
    "model_count": {
      "type": "integer"
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider",
          "model",
          "source",
          "proof"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "proof": {
            "enum": [
              "configured",
              "endpoint",
              "env-curated",
              "user-preferred"
            ]
          },
          "base_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "context_length": {
            "type": [
              "integer",
              "null"
            ]
          },
          "supports_tools": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "score": {
            "type": [
              "number",
              "null"
            ]
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "needs_validation": {
            "type": "boolean"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}